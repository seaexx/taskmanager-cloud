################################################################################
# .gitignore for Kubernetes/DevOps Projects
# Generated on: $(date)
# 
# This file excludes sensitive data, secrets, generated files, and 
# environment-specific configurations from version control.
################################################################################

#==============================================================================
# CRITICAL: SECRETS & CREDENTIALS (NEVER COMMIT THESE!)
#==============================================================================

# Private keys and certificates
*.key
*.pem
*.crt
*.p12
*.pfx
*.cer
*.der

# Kubernetes secrets (if they contain actual values)
*-secret.yaml
*-secrets.yaml
*/secrets/
secrets/
secret.yaml
secret.yml

# Environment files
.env
.env.*
.env.example
.env.template
.env.sample

# Credentials and config files
credentials.json
credentials.yml
credentials.yaml
config.local.*
kubeconfig
.kube/config
.kube/cache/

# Cloud provider credentials
.aws/credentials
.aws/config
.azure/
.gcloud/
.do/

# Terraform sensitive files
*.tfstate
*.tfstate.*
*.tfstate.backup
terraform.tfvars
terraform.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform/
.terraform.lock.hcl

# Ansible vault files (if unencrypted)
vault-password.txt
*vault*.key

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.ppk

# API keys and tokens
*apikey*
*api-key*
*token*
!*token*.example

# Database connection strings
database.yml
database.yaml
db-config.*

# Docker registry credentials
.docker/config.json
.dockercfg

# CI/CD secrets
.gitlab-ci-variables.yml
.circleci/config.local.yml

#==============================================================================
# GENERATED FILES & BUILD ARTIFACTS
#==============================================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm
.yarn-integrity
dist/
build/
.next/
out/
.nuxt/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Go
# Binary names
*.exe
*.exe~
*.dll
*.so
*.dylib
vendor/

# Java
target/
*.class
*.jar
*.war
*.ear
*.nar

# Ruby
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/tmp/
.bundle/
vendor/bundle

#==============================================================================
# LOGS & TEMPORARY FILES
#==============================================================================

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
tmp/
temp/
cache/
.cache/

#==============================================================================
# OPERATING SYSTEM FILES
#==============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

#==============================================================================
# EDITOR & IDE FILES
#==============================================================================

# Visual Studio Code
.vscode/
.vscode-test/
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm, etc.)
.idea/
*.iml
*.ipr
*.iws
out/
.idea_modules/

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
[._]*.un~

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
.org-id-locations
*_archive
*_flymake.*
*.rel

# Sublime Text
*.sublime-workspace
*.sublime-project
.sublime-project

# Eclipse
.classpath
.project
.settings/
.metadata/
bin/
*.launch
*.pydevproject
.cproject
.autotools
.buildpath
.externalToolBuilders/
.target

# Xcode
xcuserdata/
*.xcscmblueprint
*.xccheckout

#==============================================================================
# KUBERNETES SPECIFIC
#==============================================================================

# Minikube
.minikube/

# Helm
.helm/
*.tgz
charts/*.tgz

# Kustomize cache
.kustomize/

# Kind (Kubernetes in Docker)
.kind/

# K3s
.k3s/

# Kubernetes dashboard tokens
dashboard-token.txt

#==============================================================================
# DOCKER
#==============================================================================

# Docker volumes and data
docker-compose.override.yml
.dockerignore.local

#==============================================================================
# TESTING & COVERAGE
#==============================================================================

# Coverage reports
coverage/
*.cover
*.coverage
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.pytest_cache/
.nyc_output/
lcov.info
coverage.xml

# Test artifacts
.testmondata
junit.xml

#==============================================================================
# MONITORING & OBSERVABILITY
#==============================================================================

# Prometheus data
prometheus-data/

# Grafana
grafana-data/

#==============================================================================
# DATABASE & DATA FILES
#==============================================================================

# SQLite
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm

# PostgreSQL
*.sql.gz
*.dump

# Data directories
data/
db-data/
postgres-data/
mysql-data/
mongo-data/

#==============================================================================
# PACKAGE MANAGER FILES (Keep lock files!)
#==============================================================================

# Note: We KEEP lock files for reproducibility
# !package-lock.json
# !yarn.lock
# !Gemfile.lock
# !poetry.lock
# !Pipfile.lock

#==============================================================================
# MISC
#==============================================================================

# Backup files
*.orig
*.rej

# Compressed files (unless part of release)
# *.zip
# *.tar
# *.gz
# *.rar

# Large binary files
*.iso
*.dmg

# Output directories
output/
outputs/
results/

# Debug files
debug.log
error.log

#==============================================================================
# PROJECT SPECIFIC (Uncomment as needed)
#==============================================================================

# Uncomment these if you need them:
# /vendor/
# /uploads/
# /storage/
# /.vagrant/

#==============================================================================
# KEEP THESE FILES (Exceptions)
#==============================================================================

# Example/template files should be committed
!.env.example
!.env.template
!config.example.yaml
!secret.example.yaml
!kubeconfig.example

# Keep .gitkeep files (for tracking empty directories)
!.gitkeep

# Keep README files
!README.md
!*/README.md

################################################################################
# END OF .gitignore
################################################################################
